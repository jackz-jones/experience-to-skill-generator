{
  "name": "experience-to-skill-generator",
  "displayName": "Experience-to-Skill Generator",
  "description": "自动将会话历史转化为可复用的技能，用于知识沉淀和技能开发",
  "version": "0.2.0",
  "author": "jackz-jones",
  "license": "Apache-2.0",
  "categories": ["productivity", "ai", "skills", "automation"],
  "tags": ["session-analysis", "skill-generation", "knowledge-management"],

  "requirements": {
    "python": ">=3.8",
    "memory": ">=4GB",
    "dependencies": {
      "optional_packages": []
    }
  },

  "tools": [
    {
      "name": "extract",
      "description": "预处理会话文件：读取、脱敏、归一化、分段，输出结构化文本供 LLM 分析（不做语义分析）",
      "parameters": {
        "type": "object",
        "properties": {
          "session_path": {
            "type": "string",
            "description": "会话文件或目录路径"
          },
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          },
          "max_chunks": {
            "type": "integer",
            "description": "最大分段数量（0 表示不限制）",
            "default": 0
          }
        },
        "required": ["session_path"]
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} --input '${session_path}' extract ${max_chunks:+--max-chunks ${max_chunks}}"
      }
    },
    {
      "name": "analyze",
      "description": "读取并分析会话，输出结构化的分析结果（不写入 SKILL 文件）",
      "parameters": {
        "type": "object",
        "properties": {
          "session_path": {
            "type": "string",
            "description": "会话文件或目录路径"
          },
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          },
          "json_lines": {
            "type": "boolean",
            "description": "是否以紧凑 JSON 输出，便于脚本解析",
            "default": false
          }
        },
        "required": ["session_path"]
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} --input '${session_path}' analyze ${json_lines:+--json-lines}"
      }
    },
    {
      "name": "generate",
      "description": "生成 SKILL 文件。可通过 analysis_json 传入 LLM 分析结果，或省略则使用内置规则引擎",
      "parameters": {
        "type": "object",
        "properties": {
          "session_path": {
            "type": "string",
            "description": "会话文件或目录路径"
          },
          "output_dir": {
            "type": "string",
            "description": "可选：SKILL 输出目录，覆盖配置中的 output.target_dir"
          },
          "conflict_strategy": {
            "type": "string",
            "description": "同名 SKILL 冲突处理策略",
            "enum": ["rename", "skip", "overwrite", "merge", "fail"]
          },
          "skill_name": {
            "type": "string",
            "description": "可选：指定生成的 SKILL 名称"
          },
          "analysis_json": {
            "type": "string",
            "description": "可选：LLM 分析结果 JSON（包含 tasks/key_steps/constraints/keywords/confidence 字段）。传入则跳过内置规则引擎"
          },
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          },
          "preserve_raw": {
            "type": "boolean",
            "description": "保留原始会话内容（启用前请确认不会泄露敏感信息）",
            "default": false
          }
        },
        "required": ["session_path"]
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} --input '${session_path}' ${output_dir:+--output-dir '${output_dir}'} ${conflict_strategy:+--conflict ${conflict_strategy}} ${preserve_raw:+--preserve-raw} generate ${skill_name:+--name '${skill_name}'} ${analysis_json:+--analysis '${analysis_json}'}"
      }
    },
    {
      "name": "diagnose",
      "description": "诊断运行环境、配置和会话来源，定位问题",
      "parameters": {
        "type": "object",
        "properties": {
          "session_path": {
            "type": "string",
            "description": "会话文件或目录路径"
          },
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          },
          "json_lines": {
            "type": "boolean",
            "description": "是否以紧凑 JSON 输出，便于脚本解析",
            "default": false
          }
        },
        "required": ["session_path"]
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} --input '${session_path}' diagnose ${json_lines:+--json-lines}"
      }
    },
    {
      "name": "config",
      "description": "显示合并后的配置和适配策略，便于排查 agent 自动检测结果",
      "parameters": {
        "type": "object",
        "properties": {
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          }
        },
        "required": []
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} config"
      }
    },
    {
      "name": "validate-config",
      "description": "校验配置文件、环境变量与 CLI 覆盖项是否合法",
      "parameters": {
        "type": "object",
        "properties": {
          "config_path": {
            "type": "string",
            "description": "可选：自定义配置文件（JSON）路径"
          }
        },
        "required": []
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py ${config_path:+--config '${config_path}'} validate-config"
      }
    },
    {
      "name": "setup-agent",
      "description": "为指定 agent 生成项目级工作流指引文件（如 CLAUDE.md、.cursorrules），让 agent 自动学会 extract → LLM 分析 → generate 的完整流程",
      "parameters": {
        "type": "object",
        "properties": {
          "agent_type": {
            "type": "string",
            "description": "目标 agent 类型",
            "enum": ["claude-code", "cursor", "windsurf"]
          },
          "output": {
            "type": "string",
            "description": "可选：输出目录（默认当前目录）"
          },
          "force": {
            "type": "boolean",
            "description": "覆盖已存在的指引文件",
            "default": false
          },
          "dry_run": {
            "type": "boolean",
            "description": "仅预览生成内容，不写入文件",
            "default": false
          }
        },
        "required": ["agent_type"]
      },
      "command": {
        "type": "exec",
        "script": "python3 python-scripts/universal_skill_generator.py setup-agent ${agent_type} ${output:+--output '${output}'} ${force:+--force} ${dry_run:+--dry-run}"
      }
    }
  ],

  "mcp": {
    "enabled": false,
    "description": "暂未启用 MCP 服务"
  },

  "defaultConfiguration": {
    "agent": "auto",
    "compatibility_mode": true,
    "session_sources": [
      {
        "type": "openclaw",
        "path": "~/.openclaw/workspace/memory",
        "patterns": ["*.json", "*.jsonl", "*.md", "*.txt"]
      },
      {
        "type": "openclaw",
        "path": "~/.openclaw/agents",
        "patterns": ["*.jsonl", "*.json"]
      }
    ],
    "output": {
      "target_dir": "generated_skills",
      "format": "markdown",
      "conflict_strategy": "rename",
      "metadata_format": "generic"
    },
    "analysis": {
      "min_score": 50,
      "max_chars": 120000,
      "chunk_chars": 30000,
      "confidence_threshold": 0.55
    },
    "security": {
      "redact_sensitive": true,
      "preserve_raw": false
    },
    "templates": {
      "skill": "standard",
      "include_sources": true
    },
    "adapters": {}
  },

  "examples": [
    {
      "description": "分析会话并生成 SKILL 文件",
      "command": "generate {\"session_path\": \"~/.openclaw/agents\", \"output_dir\": \"./generated_skills\", \"conflict_strategy\": \"rename\"}"
    },
    {
      "description": "仅分析会话，输出结构化结果",
      "command": "analyze {\"session_path\": \"./sessions/example.json\", \"json_lines\": true}"
    },
    {
      "description": "诊断运行环境和会话来源",
      "command": "diagnose {\"session_path\": \"~/.openclaw/agents\"}"
    },
    {
      "description": "查看合并后的配置和适配策略",
      "command": "config {}"
    },
    {
      "description": "校验配置文件",
      "command": "validate-config {\"config_path\": \"./my-config.json\"}"
    }
  ]
}